{
  "_comment": "MCP Server Secrets Configuration - Copy to mcp_secrets.json and customize",

  "api_keys": {
    "_comment": "API Keys for authentication. Can be plain text or SHA256 hashed.",
    "admin": "your-admin-api-key-here",
    "client_a": "client-a-secret-key",
    "readonly": "readonly-access-key"
  },

  "bearer_tokens": {
    "_comment": "Bearer tokens with optional metadata. Token string as key, metadata object as value.",

    "mcp_prod_token_xxxxx": {
      "created_at": "2025-03-10T00:00:00Z",
      "expires_at": "2026-03-10T00:00:00Z",
      "scopes": ["tools:read", "tools:execute", "resources:read"],
      "description": "Production token"
    },

    "mcp_dev_token_xxxxx": {
      "created_at": "2025-03-10T00:00:00Z",
      "expires_at": null,
      "scopes": ["tools:read", "tools:execute", "resources:read", "resources:write", "prompts:read"],
      "description": "Development token - full access"
    }
  },

  "_environment_variables": {
    "_comment": "Alternative: Use environment variables instead of this file",
    "MCP_AUTH_MODE": "api_key | bearer_token | both | none",
    "MCP_API_KEYS": "key1,key2,key3 (comma-separated)",
    "MCP_BEARER_TOKENS": "token1,token2,token3 (comma-separated)",
    "MCP_SECRETS_FILE": "path/to/custom/secrets.json"
  }
}
